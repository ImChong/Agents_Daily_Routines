# Hermes 每日任务配置文件示例
# 将此文件复制为 ~/.hermes-daily-config.env 并填写实际值
# 注意：此文件包含敏感信息，不要提交到版本控制

# 飞书主频道ID（从飞书Webhook或机器人配置获取）
FEISHU_HOME_CHANNEL="oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Robotics_Notebooks 仓库本地路径
ROBOTICS_NOTEBOOKS_PATH="/home/username/path/to/Robotics_Notebooks"

# 可选：其他配置
# HERMES_PATH="/usr/local/bin/hermes"
# LOG_LEVEL="INFO"

# 使用说明：
# 1. 复制此文件：cp hermes-daily-config.example.env ~/.hermes-daily-config.env
# 2. 编辑配置文件：vim ~/.hermes-daily-config.env
# 3. 填写实际的频道ID和仓库路径
# 4. 确保配置文件权限安全：chmod 600 ~/.hermes-daily-config.env